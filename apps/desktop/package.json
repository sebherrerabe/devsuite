{
  "name": "@devsuite/desktop",
  "productName": "DevSuite",
  "version": "0.1.4",
  "description": "Windows desktop shell for DevSuite",
  "author": "DevSuite",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm run build && node scripts/run-electron.mjs",
    "build": "tsc -p tsconfig.json && node scripts/bundle-preload.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "verify:assets": "node scripts/verify-build-assets.mjs",
    "build:all": "pnpm run verify:assets && pnpm --filter @devsuite/shared build && pnpm --filter @devsuite/web build && pnpm run build && node scripts/copy-renderer.mjs",
    "start": "node scripts/run-electron.mjs",
    "package": "pnpm run build && electron-builder --dir --config electron-builder.config.cjs",
    "make:win": "pnpm run build:all && electron-builder --win nsis --x64 --publish never --config electron-builder.config.cjs",
    "test:int": "tsx --test test/integration/**/*.test.ts",
    "test:e2e": "pnpm run build && node scripts/run-e2e.mjs",
    "test:install-smoke": "pnpm run make:win && node scripts/run-install-smoke.mjs",
    "test:install-smoke:existing": "node scripts/run-install-smoke.mjs",
    "test:process-overhead": "pnpm run build && node scripts/process-monitor-overhead.mjs",
    "test:unit": "tsx --test test/unit/**/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devsuite/shared": "workspace:^",
    "@mapbox/node-pre-gyp": "^1.0.11",
    "active-win": "^9.0.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@wdio/cli": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "bmp-js": "^0.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.3",
    "expect-webdriverio": "^5.4.3",
    "png-to-ico": "^2.1.2",
    "sharp": "^0.34.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wdio-electron-service": "^9.2.1",
    "webdriverio": "^9.20.0"
  }
}
