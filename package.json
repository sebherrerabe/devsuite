{
  "name": "devsuite",
  "private": true,
  "type": "module",
  "description": "DevSuite - Developer Productivity Platform",
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=!@devsuite/desktop run dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @devsuite/shared build && pnpm --filter @devsuite/web build",
    "build:web:ci": "pnpm install --filter @devsuite/web... && pnpm run build:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "clean": "pnpm -r run clean",
    "test": "echo 'Tests will be implemented in future projects'",
    "test:performance": "tsx --test convex/lib/performanceMetrics.test.ts convex/lib/performanceDashboard.test.ts",
    "test:gh-notification": "tsx --test convex/lib/githubIngestDecision.test.ts convex/lib/inboxPushEligibility.test.ts convex/lib/githubThreadSelection.test.ts apps/gh-service/src/gh-runner.test.ts apps/gh-service/src/notification-sync.test.ts apps/gh-service/src/convex-backend-client.test.ts apps/web/src/lib/inbox-desktop-notifications-context.test.ts",
    "test:security": "tsx --test convex/lib/helpers.security.test.ts convex/http.security.test.ts convex/betterAuth/auth.security.test.ts apps/gh-service/src/auth.security.test.ts apps/gh-service/src/config.security.test.ts apps/gh-service/src/token-cipher.security.test.ts apps/gh-service/src/server.security.test.ts apps/notion-service/src/auth.security.test.ts apps/notion-service/src/config.security.test.ts apps/notion-service/src/token-cipher.security.test.ts apps/notion-service/src/server.security.test.ts",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "basic-ftp": "^5.2.0",
      "express-rate-limit": "^8.3.1",
      "hono": "^4.12.4",
      "rollup": "^4.59.0",
      "serialize-javascript": "^7.0.3"
    }
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "convex": "^1.31.6",
    "eslint": "9",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
