# DevSuite Environment Variables
# This file documents all environment variables used by DevSuite.
# Copy this to .env.local and fill in your values.

# ============================================================================
# Convex Cloud Setup
# ============================================================================
# Required: Convex deployment URL (unique per Convex project).
# Set after running `npx convex dev` and creating a project.
# Format: https://<deployment>.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Optional: Convex deployment name (used for `npx convex deploy`).
# Defaults to "prod" if not set. Usually not needed for local dev.
CONVEX_DEPLOYMENT=

# ============================================================================
# Better Auth Configuration
# ============================================================================
# IMPORTANT: Better Auth server environment variables are set via Convex (not local .env).
# These are documented here for reference only.
#
# Set these in your Convex Cloud project using:
#   npx convex env set BETTER_AUTH_SECRET <value>
#   npx convex env set SITE_URL <value>
#
# BETTER_AUTH_SECRET: Random 32+ character string for signing auth tokens.
#   Generate with: openssl rand -base64 32
#   Set in Convex Cloud: npx convex env set BETTER_AUTH_SECRET <value>
#
# SITE_URL: Public URL of your app (e.g., http://localhost:5173 for local dev,
#   https://example.com for production).
#   Set in Convex Cloud: npx convex env set SITE_URL <value>

# ============================================================================
# MCP Server Configuration (Optional)
# ============================================================================
# Static token for securing MCP server access.
# Only needed if running the MCP server or integrating with Claude/external AI.
MCP_TOKEN=

# ============================================================================
# GitHub Service Configuration (Optional during scaffolding)
# ============================================================================
# Host and port for the standalone GitHub integration service.
DEVSUITE_GH_SERVICE_HOST=0.0.0.0
DEVSUITE_GH_SERVICE_PORT=8790
# Base URL used by server-side callers (e.g., MCP) to reach gh-service.
DEVSUITE_GH_SERVICE_URL=http://localhost:8790
#
# Service token used by backend callers when invoking protected GH service routes.
# Optional for local development, required in production deployments.
DEVSUITE_GH_SERVICE_TOKEN=
#
# Comma-separated allowlist of web origins that can call GH service endpoints.
DEVSUITE_GH_SERVICE_CORS_ORIGINS=http://localhost:5173
#
# Directory where gh-service stores per-user connection metadata.
DEVSUITE_GH_SERVICE_DATA_DIR=
#
# Base64-encoded 32-byte key for encrypting GitHub tokens at rest.
# Generate with: openssl rand -base64 32
DEVSUITE_GH_SERVICE_ENCRYPTION_KEY=
#
# OAuth app client id used for GitHub device flow.
# Default uses the GitHub CLI OAuth app.
DEVSUITE_GH_OAUTH_CLIENT_ID=178c6fc778ccc68e1d6a
#
# Comma-separated scopes requested during device flow login.
DEVSUITE_GH_OAUTH_SCOPES=repo,read:org,gist,notifications
#
# Shared backend token used by gh-service when calling Convex HTTP ingestion routes.
# Must match Convex env var of the same name.
DEVSUITE_GH_SERVICE_BACKEND_TOKEN=
#
# Enable/disable background notification polling in gh-service.
DEVSUITE_GH_SERVICE_NOTIFICATION_POLL_ENABLED=true
#
# Poll interval for GitHub notifications (minimum 10000 ms).
# Defaults to 60000 in development and 300000 in production when omitted.
DEVSUITE_GH_SERVICE_NOTIFICATION_POLL_INTERVAL_MS=60000
#
# Max notifications fetched per user per polling cycle (1-100).
DEVSUITE_GH_SERVICE_NOTIFICATION_BATCH_SIZE=50
#
# Convex site URL used by gh-service for backend ingestion.
# Example: https://<deployment>.convex.site
DEVSUITE_CONVEX_SITE_URL=

# ============================================================================
# Notion Service Configuration (Optional during scaffolding)
# ============================================================================
# Host and port for the standalone Notion integration service.
DEVSUITE_NOTION_SERVICE_HOST=0.0.0.0
DEVSUITE_NOTION_SERVICE_PORT=8791
# Base URL used by server-side callers to reach notion-service.
DEVSUITE_NOTION_SERVICE_URL=http://localhost:8791
#
# Service token used by backend callers when invoking protected Notion service routes.
# Optional for local development, required in production deployments.
DEVSUITE_NOTION_SERVICE_TOKEN=
#
# Comma-separated allowlist of web origins that can call Notion service endpoints.
DEVSUITE_NOTION_SERVICE_CORS_ORIGINS=http://localhost:5173
#
# Directory where notion-service stores per-user connection metadata.
DEVSUITE_NOTION_SERVICE_DATA_DIR=
#
# Base64-encoded 32-byte key for encrypting Notion tokens at rest.
# Generate with: openssl rand -base64 32
DEVSUITE_NOTION_SERVICE_ENCRYPTION_KEY=
#
# Shared backend token used by notion-service when calling Convex HTTP routes.
# Must match Convex env var DEVSUITE_NOTION_SERVICE_BACKEND_TOKEN.
DEVSUITE_NOTION_SERVICE_BACKEND_TOKEN=
#
# Notion OAuth configuration for UI-based pairing flow.
# Configure these in your Notion public integration settings.
DEVSUITE_NOTION_OAUTH_CLIENT_ID=
DEVSUITE_NOTION_OAUTH_CLIENT_SECRET=
# Must match the callback URL configured in Notion exactly.
# Example: http://localhost:8791/notion/connect/callback
DEVSUITE_NOTION_OAUTH_REDIRECT_URI=
# Where users are redirected in the web app after OAuth callback handling.
# Example: http://localhost:5173/settings/integrations
DEVSUITE_NOTION_POST_AUTH_REDIRECT_URL=
#
# Optional shared secret for verifying Notion webhook signatures.
# Set this to the same verification token configured in Notion webhooks.
DEVSUITE_NOTION_WEBHOOK_VERIFICATION_TOKEN=

# ============================================================================
# Web Push Configuration (Convex + Frontend)
# ============================================================================
# VAPID keys used for browser push notifications.
# Generate with: npx web-push generate-vapid-keys
# Set PUBLIC and PRIVATE in Convex envs. Only PUBLIC is exposed to the browser.
DEVSUITE_WEB_PUSH_VAPID_PUBLIC_KEY=
DEVSUITE_WEB_PUSH_VAPID_PRIVATE_KEY=
# Contact URL/email used as VAPID subject.
# Examples: mailto:alerts@example.com or https://example.com
DEVSUITE_WEB_PUSH_VAPID_SUBJECT=

# ============================================================================
# Frontend Configuration
# ============================================================================
# Vite uses VITE_ prefix for client-side variables.
# VITE_CONVEX_URL: Convex deployment URL (same value as NEXT_PUBLIC_CONVEX_URL).
VITE_CONVEX_URL=
#
# VITE_CONVEX_SITE_URL: Same as VITE_CONVEX_URL but ends in `.site`.
# This is required for Better Auth React SPA cross-domain auth flows.
VITE_CONVEX_SITE_URL=
#
# VITE_SITE_URL: Your local / public site URL (should match the Convex `SITE_URL` env var).
VITE_SITE_URL=
#
# Optional override for the GitHub service base URL used by the web app.
# Defaults to http://localhost:8790 if not set.
VITE_GH_SERVICE_URL=http://localhost:8790
#
# Optional override for the Notion service base URL used by the web app.
# Defaults to http://localhost:8791 if not set.
VITE_NOTION_SERVICE_URL=http://localhost:8791
#
# Public VAPID key for web push subscription registration in the browser.
# Must match DEVSUITE_WEB_PUSH_VAPID_PUBLIC_KEY configured in Convex.
VITE_WEB_PUSH_VAPID_PUBLIC_KEY=
